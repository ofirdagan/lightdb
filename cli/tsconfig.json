{
  "compilerOptions": {
    "esModuleInterop": true,
    "moduleResolution": "node16",
    "sourceMap": true,
    "lib": ["ES2023", "DOM"],
    "module": "Node16",
    "target": "ES2022",
    "outDir": "./dist",
    "rootDir": "./src",
    "types": ["node"],
    "strict": true,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "../node_modules"
  ]
}
